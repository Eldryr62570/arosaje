{% extends 'base.html.twig' %}

{% block title %}A'Rosa-je{% endblock %}

  {% block stylesheets %}
      {{encore_entry_link_tags("a")}}
      {{ parent() }}
    {% endblock %}
    {% block javascripts %}
      {{encore_entry_script_tags("home")}}
      {{ parent() }}
    {% endblock %}

{% block body %}
<img class="absolute right-0 sm:left-0 w-16 m-4" src="{{asset('build/img/icon-logo.png')}}" alt="icon arosaje">
  <section class="h-screen w-full bg-slate-50 bg-cover flex" style="background-image: url('{{asset('build/img/1.jpg')}}')">
    <div data-aos="fade-up" class="flex flex-col justify-center sm:block w-10/12 h-fit sm:w-2/3 mx-auto sm:my-auto">
      <h1 class="mt-8 text-4xl sm:text-6xl font-mont"><span class="font-bold text-rose-500">A’rosa-je</span>, la solution collaborative pour le bien-être floral.</h1>
      
      <h2 class="mt-2 text-gray-600 font-light font-romono text-base sm:text-2xl">
        Devenez acteur au sein d’une communauté grandissante d’horticulteurs amateurs ou confirmés à travers l’entraide et le partage.
        {#Nous vous accompagnons avec nos 1500 botanistes, passionnés et investis dans l'assurance de la santé de vos plantes.
         Demandez aux membres de la communauté de prendre soin de vos plantes pendant vos absences et aidez à votre tour, tout en renforçant votre connaissance de la flore. #}
      </h2>
      <div class="flex flex-col sm:flex-row sm:justify-between">
        <a href="#" class="text-rose-500 font-roboto text-base font-light mt-3 mb-8 sm:mb-0 hover:underline">En savoir plus..</a>
        <button class="m-auto mt-2 sm:mx-0 group relative h-12 w-60 overflow-hidden rounded-lg bg-white text-lg shadow">
          <div class="absolute inset-0 w-3 bg-rose-500 transition-all duration-[250ms] ease-out group-hover:w-full"></div>
          <span class="relative text-black group-hover:text-white">Découvrir la carte</span>
        </button>
      </div>
    </div>
    <a href="#card" class="absolute bottom-4 left-1/2 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="currentColor" class="bi bi-chevron-down" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
      </svg>
    </a>
  </section>

  <section id="card" class="h-fit w-full bg-slate-50">

    {# <img class="max-w-none" src="{{asset('build/img/entraider.jpg')}}" alt="motif min"> #}
    <div data-aos="fade-up" class="h-auto w-24 hidden sm:block">
        <span class="text-slate-800 font-bold font-mont text-5xl whitespace-nowrap origin-bottom-left absolute -bottom-28 left-9 rotate-90">NOS PRINCIPES</span>
    </div>
    <div  class="flex pt-6 sm:hidden">
        <span class="m-auto text-slate-800 font-bold font-mont text-3xl text-center">NOS PRINCIPES</span>
    </div>
    <div class="h-fit gap-8 grid grid-cols-[repeat(auto-fit,320px)] py-8 sm:py-20 mx-auto sm:mx-12 md:mx-20 justify-center md:justify-evenly">
      
        <div class="max-w-[16rem] sm:max-w-[18rem] mx-auto xs:max-w-lg">
          <div data-aos="fade-left" class="border-2 border-rose-400 relative bottom-2 left-6 rounded-lg"></div>
            <div class=" bg-white rounded-xl">
                <a href="#">
                    <img class="rounded-t-xl" src="{{asset('build/img/entraider.jpg')}}" alt="entraide" />
                </a>
                <div class="p-5">
                    <a href="#">
                        <h5 class="mb-2 text-3xl font-medium tracking-tight font-mont">Entraide</h5>
                    </a>
                    <p class="my-3 font-base text-gray-600 font-light font-romono">Faites garder vos plantes par d'autres membres de la communauté lors de vos abscences.</p>
                    <img class="w-16 m-auto hover:animate-spin" src="{{asset('build/img/icon-logo.png')}}" alt="icon arosaje">
                </div>
            </div>
          <div data-aos="fade-right" class="border-2 border-rose-400 relative top-2 right-6 rounded-lg"></div>
        </div>

        <div class="max-w-[16rem] sm:max-w-[18rem] mx-auto xs:max-w-lg">
          <div data-aos="fade-left" class="border-2 border-rose-400 relative bottom-2 left-6 rounded-lg"></div>
            <div class="bg-white rounded-xl">
                <a href="#">
                    <img class="rounded-t-xl" src="{{asset('build/img/informer.jpg')}}" alt="entraide" />
                </a>
                <div class="p-5">
                    <a href="#">
                        <h5 class="mb-2 text-3xl font-medium tracking-tight font-mont">Partage</h5>
                    </a>
                    <p class="my-3 font-base text-gray-600 font-light font-romono">Surveillez l'évolution de vos plantes au moyen de photos après chaque séance d'entretien.</p>
                    <img class="w-16 m-auto hover:animate-spin" src="{{asset('build/img/icon-logo.png')}}" alt="icon arosaje">
                </div>
            </div>
          <div data-aos="fade-right" class="border-2 border-rose-400 relative top-2 right-6 rounded-lg"></div>
        </div>

        <div class="max-w-[16rem] sm:max-w-[18rem] mx-auto xs:max-w-lg">
          <div data-aos="fade-left" class="border-2 border-rose-400 relative bottom-2 left-6 rounded-lg"></div>
            <div class="bg-white rounded-xl">
                <a href="#">
                    <img class="rounded-t-xl" src="{{asset('build/img/apprendre.jpg')}}" alt="entraide" />
                </a>
                <div class="p-5">
                    <a href="#">
                        <h5 class="mb-2 text-3xl font-medium tracking-tight font-mont">Connaissance</h5>
                    </a>
                    <p class="my-3 font-base text-gray-600 font-light font-romono">Entourez-vous de nos 1500 botanistes professionnels, affiliés à A'rosa-je.</p>
                    <img class="w-16 m-auto hover:animate-spin" src="{{asset('build/img/icon-logo.png')}}" alt="icon arosaje">
                </div>
            </div>
          <div data-aos="fade-right" class="border-2 border-rose-400 relative top-2 right-6 rounded-lg"></div>
        </div>
        
    </div>
  </section>

<section class="bg-slate-50 h-fit lg:h-[calc(theme('height.screen')-80px)] block lg:flex">
    <div data-aos="fade-left" class="bg-rose-400 text-white text-sm lg:text-base font-romono p-8 flex flex-col justify-center h-[calc(50%-40px)] lg:h-full lg:w-1/2">
      <span class="text-8xl text-rose-600 font-space relative top-10 right-8">“</span>
        <h2 class="font-mont text-lg lg:text-2xl mb-4"><strong>A’rosa-je</strong> aide les particuliers à prendre soin de leurs plantes.</h2>
        <p>Fondé en 1984, nous étions initialement composés d'une petite équipe de botanistes à <strong>Bourges</strong>. Nous sommes désormais composés de plus de 1500 botanistes répartis à travers la France qui servent les propriétaires de plantes de deux manières :</p>
        <ul class="my-4">
          <li>- En allant garder leurs plantes lorsque les propriétaires sont absents</li>
          <li>- En prodiguant des conseils d’entretien afin que les propriétaires s’occupent de mieux en mieux de leurs plantes.</li>
        </ul>
        <p>À la suite de la pandémie et d'une forte augmentation de la demande Nous avons décidé d'élaborer une option communautaire en ligne.</p>
      <span class="flex justify-end text-8xl text-rose-600 font-space relative bottom-16 left-6">„</span>
    </div>
    <div id="slider-section" class="h-[calc(50%+40px) lg:w-1/2 ">
        <div id="slider" class="h-96 lg:h-[calc(theme('height.screen')-80px)]">
            <div class="w-full h-96 lg:h-[calc(theme('height.screen')-80px)] lg:w-1/2 absolute opacity-0 ease-linear duration-300 bg-cover active-slide"></div>
            <div class="w-full h-96 lg:h-[calc(theme('height.screen')-80px)] lg:w-1/2 absolute opacity-0 ease-linear duration-300 bg-cover "></div>
            <div class="w-full h-96 lg:h-[calc(theme('height.screen')-80px)] lg:w-1/2 absolute opacity-0 ease-linear duration-300 bg-cover "></div>
            <div class="w-full h-96 lg:h-[calc(theme('height.screen')-80px)] lg:w-1/2 absolute opacity-0 ease-linear duration-300 bg-cover "></div>
        </div>
        <div id="choice-slide" class="bg-slate-50 rounded-md relative bottom-4 left-4 w-32 h-2 flex">
            <div data-id='0' class='w-1/4 h-full rounded-l-md ease-linear duration-300 cursor-pointer bg-rose-500'></div>
            <div data-id='1' class='w-1/4 h-full ease-linear duration-300 cursor-pointer'></div>
            <div data-id='2' class='w-1/4 h-full ease-linear duration-300 cursor-pointer'></div>
            <div data-id='3' class='w-1/4 h-full rounded-r-md ease-linear duration-300 cursor-pointer'></div>
        </div>
    </div>
</section>

